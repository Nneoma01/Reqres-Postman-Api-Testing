    {
      "name": "Get All Users",
      "item": [
        {
          "name": "Get All Users 2OO OK",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is under 1000ms\", () => {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "});\r",
                  "\r",
                  "const response = pm.response.json()\r",
                  "\r",
                  "pm.test(\"JSON Response returns data \", () => {\r",
                  "    pm.expect(response.data).to.be.an(\"array\");\r",
                  "    pm.expect(response.data.length).to.be.greaterThan(0);\r",
                  "}); \r",
                  "\r",
                  "pm.test(\"Validate corerct JSON variables are returned in response\", function () {\r",
                  "    pm.expect(response.data[0]).to.have.property(\"id\");\r",
                  "    pm.expect(response.data[0]).to.have.property(\"email\");\r",
                  "    pm.expect(response.data[0]).to.have.property(\"first_name\");\r",
                  "    pm.expect(response.data[0]).to.have.property(\"last_name\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"return users email value in response\", function () {\r",
                  "    pm.expect(response.data.map((value) => value.email));\r",
                  "    // console.log(response.data.map((value) => value.email));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Validate users email value in response\", function () {\r",
                  "    pm.expect(response.data[0].email).to.eql(\"george.bluth@reqres.in\");\r",
                  "\r",
                  "});\r",
                  "\r",
                  "// We can use any of the belo wayds to save/set user ID\r",
                  "pm.test(\"Save user ID for next request\", () => {\r",
                  "    pm.collectionVariables.set(\"user_id\", response.data[0].id);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Save users ID\", function () {\r",
                  "    // for(i=0; i<response.data.length; i++){\r",
                  "    //     if(response.data[0].id === 1){\r",
                  "    //         pm.collectionVariables.set(\"userID\", response.data[0].id)\r",
                  "    //     }\r",
                  "    // }\r",
                  "   const UserID = response.data.map((value) => value.id);\r",
                  "   console.log(UserID);\r",
                  "   pm.collectionVariables.set(\"UserID\", UserID[0]);\r",
                  "\r",
                  "//    to get id of a particular users so that if users are updated and id of this user changes, we can still locate it....we are using the user name to map id as name can't change but id can\r",
                  "    const specificUserID = response.data.map((value) => value.email);\r",
                  "    pm.collectionVariables.set(\"specificUserID\", response.data[specificUserID.indexOf(\"emma.wong@reqres.in\")].id);\r",
                  "    \r",
                  "});\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
